
#----------------------------- Global Properties ----------------------------#

/outputDir:bin/$(Platform)
/intermediateDir:obj/$(Platform)
/platform:DesktopGL
/config:
/profile:Reach
/compress:False

#-------------------------------- References --------------------------------#


#---------------------------------- Content ---------------------------------#

#begin Entity_List/EntityList.json
/copy:Entity_List/EntityList.json

#begin Images/Graphics/logo.png
/importer:TextureImporter
/processor:TextureProcessor
/processorParam:ColorKeyColor=255,0,255,255
/processorParam:ColorKeyEnabled=True
/processorParam:GenerateMipmaps=False
/processorParam:PremultiplyAlpha=True
/processorParam:ResizeToPowerOfTwo=False
/processorParam:MakeSquare=False
/processorParam:TextureFormat=Color
/build:Images/Graphics/logo.png;Images/Graphics/logo

#begin Images/Spritesheet/Atlas_definition/atlas-definition.xml
/copy:Images/Spritesheet/Atlas_definition/atlas-definition.xml;Images/Spritesheet/Atlas_definition/atlas-definition

#begin Images/Spritesheet/Atlas_definition/player_spritesheet-definition.xml
/copy:Images/Spritesheet/Atlas_definition/player_spritesheet-definition.xml;Images/Spritesheet/Atlas_definition/player_spritesheet-definition

#begin Images/Spritesheet/Spritesheets/atlas.png
/importer:TextureImporter
/processor:TextureProcessor
/processorParam:ColorKeyColor=255,0,255,255
/processorParam:ColorKeyEnabled=True
/processorParam:GenerateMipmaps=False
/processorParam:PremultiplyAlpha=True
/processorParam:ResizeToPowerOfTwo=False
/processorParam:MakeSquare=False
/processorParam:TextureFormat=Color
/build:Images/Spritesheet/Spritesheets/atlas.png;Images/Spritesheet/Spritesheets/atlas

#begin Images/Spritesheet/Spritesheets/player_spritesheet.png
/importer:TextureImporter
/processor:TextureProcessor
/processorParam:ColorKeyColor=255,0,255,255
/processorParam:ColorKeyEnabled=True
/processorParam:GenerateMipmaps=False
/processorParam:PremultiplyAlpha=True
/processorParam:ResizeToPowerOfTwo=False
/processorParam:MakeSquare=False
/processorParam:TextureFormat=Color
/build:Images/Spritesheet/Spritesheets/player_spritesheet.png;Images/Spritesheet/Spritesheets/player_spritesheet

